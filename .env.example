# Firebase web config — copy this file to .env.local and fill in the values.
# These are public identifiers (not secrets). Security is enforced by
# Firestore rules and Firebase Auth, not by hiding these values.
#
# Find these values in: Firebase Console → Project Settings → Your apps → Web app

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Auth providers enabled in Firebase Console:
# - Email/Password ✅
# - Google ✅
# - Email link (passwordless) — TODO: enable when implementing auth UI
