# Firebase web config — copy to .env.local and fill in values from the Firebase console.
# These are public identifiers, not secrets. Security is enforced by Firestore rules + Firebase Auth.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
